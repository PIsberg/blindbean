[11.858821, "o", "\r\n"]
[13.16236, "o", "\u001b[2m# 4. Auto-generated BlindWrapper provides transparent math on ciphertext\u001b[0m\r\n"]
[13.664215, "o", "\u001b[0;32m$\u001b[0m \u001b[1mcat target/generated-sources/annotations/com/example/WalletBlindWrapper.java | grep -A 8 'public void addFunds'\u001b[0m\r\n"]
[14.067982, "o", "    public void addFunds(Ciphertext other) {\r\n        Ciphertext sum = BlindMath.add(getCiphertextFunds(), other);\r\n        entity.setFunds(sum.hexData());\r\n    }\r\n\r\n    public void subFunds(Ciphertext other) {\r\n        Ciphertext diff = BlindMath.subtract(getCiphertextFunds(), other);\r\n        entity.setFunds(diff.hexData());\r\n    }\r\n--\r\n    public void addFunds(BigInteger plain) {\r\n"]
[14.068144, "o", "        Ciphertext ct = BlindContext.getPaillier().encrypt(plain);\r\n        addFunds(ct);\r\n    }\r\n\r\n    public void subFunds(BigInteger plain) {\r\n        Ciphertext ct = BlindContext.getPaillier().encrypt(plain);\r\n        subFunds(ct);\r\n    }\r\n"]
[14.068249, "o", "\r\n"]
